FLASK_ENV=development
SECRET_KEY=dev-secret-change-me

# Postgres container (read by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev
POSTGRES_DB=workout_app
POSTGRES_HOST_PORT=5433

# SQLAlchemy connection string (read by Flask)
DATABASE_URL=postgresql+psycopg2://postgres:dev@localhost:5433/workout_app
