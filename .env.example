FLASK_ENV=development
SECRET_KEY=dev-secret-change-me
LOG_LEVEL=INFO

# CORS — "*" allows any origin (fine for dev). In prod set this to a
# comma-separated list, e.g. "https://app.example.com,https://staging.example.com".
CORS_ORIGINS=*

# JWT — generate with `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600

# Closed-registration secret. Empty/unset = registration is locked.
# Generate with the same secrets.token_hex command.
REGISTRATION_KEY=

# Postgres container (read by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev
POSTGRES_DB=workout_app
POSTGRES_HOST_PORT=5433

# SQLAlchemy connection string (read by Flask)
DATABASE_URL=postgresql+psycopg2://postgres:dev@localhost:5433/workout_app
